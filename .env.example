# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=replace_here
GITHUB_CLIENT_SECRET=replace_here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_here  # Generate with: openssl rand -base64 32

# Orgo API Key (your admin key)
ORGO_API_KEY=replace_here

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clawspot?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/clawspot?schema=public" 

# Google Auth
GOOGLE_CLIENT_ID=replace_here
GOOGLE_CLIENT_SECRET=replace_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Cron Job Secret (optional, for securing cron endpoints)
CRON_SECRET=replace_here    # Generate with: openssl rand -base64 32


# ClawSpot Stripe billing (checkout/portal/webhook)
STRIPE_SECRET_KEY=replace_here
STRIPE_PRICE_ID_STARTER=replace_here
STRIPE_PRICE_ID_PRO=replace_here
STRIPE_PRICE_ID_ENTERPRISE=replace_here
STRIPE_WEBHOOK_SECRET=replace_here
